[{"title":"CASHFLOW <b>COMMAND</b>","tag":"Income In, Money Out","blurb":"Money flows in and out every week. Today you'll learn to keep more flowing IN than OUT!","mission":"Learn to balance money coming in and going out.","feats":[["💵","Track Income"],["🧾","Watch Spending"],["⚖️","Stay Balanced"],["📊","Know Your Flow"],["🐷","Keep the Rest"]],"qTitle":"WHAT IS<br><b>CASH FLOW?</b>","what":"<b>Cash flow</b> is money coming IN minus money going OUT.","key":"Spend less than you earn and your flow stays positive.","swapBad":"“I'll spend what I have.”","swapGood":"“$10 in, only $7 out — I keep $3.”","examplesHead":"MONEY IN vs OUT","examples":[["💵","Allowance in"],["🎁","Gift money in"],["🍭","Snacks out"],["🎮","Games out"],["🐷","Savings kept"]],"stepsTitle":"BALANCE THE <b>FLOW</b>","stepsSub":"Three steps to stay positive","intro":"Follow the flow of your money…","sources":[["💵","Income"],["🧾","Expenses"],["⚖️","Balance"],["🐷","Save"]],"rule":"Keep <b>more IN</b> than OUT.","steps":[["COUNT","money in","💵"],["SUBTRACT","money out","🧾"],["KEEP","what's left","🐷"]],"example":[["💵","In","$10"],["🧾","Out","$7"],["🐷","Left","$3"]],"star":"Positive flow means money to save.","smartTitle":"MASTER YOUR <b>FLOW</b>","parts":[["IN","you earn","💵","e.g., $10"],["OUT","you spend","🧾","e.g., $7"],["LEFT","to keep","🐷","e.g., $3"]],"goal":"“Bring in $10, spend $7, keep $3 each week.”","exIcons":"💵 → 🧾 → 🐷","smartHead":"SMART CASHFLOW RULES","rules5":[["Track every dollar","Know where it goes."],["Spend less than you earn","Stay positive."],["Cut small leaks","Tiny costs add up."],["Plan before you buy","Think first."],["Save the leftover","Don't spend it all."]],"smartTip":"A steady flow beats a lucky day!","gbTitle":"SMART vs <b>LEAKY</b>","gbSub":"Cash Flow Moves","gbBody":"Some habits keep money flowing in; others let it leak out.","gbKey":"Watch what goes out.","kico":"⚖️","tip":"Check your flow every week.","badHead":"MONEY LEAKS","bad":[["🛍️","Impulse buys"],["🙈","No tracking"],["💸","Spend it all"]],"badWarn":"Small leaks drain your money fast!","goodHead":"SMART MOVES","good":[["📊","Track it"],["⚖️","Stay balanced"],["🐷","Save first"]],"goodNote":"Positive flow grows your savings!"},
{"title":"NEEDS VS <b>WANTS</b>","tag":"Must-Have or Nice-to-Have","blurb":"Some things you really need, others you just want. Learn to tell them apart and beat the buy-it-now urge!","mission":"Learn to tell needs from wants before you spend.","feats":[["🍎","Spot Needs"],["🎮","Spot Wants"],["🧠","Think First"],["✋","Beat Impulse"],["💪","Choose Smart"]],"qTitle":"NEEDS VS<br><b>WANTS?</b>","what":"A <b>need</b> is something you must have; a want is something nice to have.","key":"Cover your needs first, then pick a want.","swapBad":"“I want it, so I'll buy it now.”","swapGood":"“Do I need this, or just want it?”","examplesHead":"NEED vs WANT","examples":[["🍎","Food: need"],["👟","Shoes: need"],["🎮","Game: want"],["🍦","Candy: want"],["🎧","Earbuds: want"]],"stepsTitle":"NEED OR <b>WANT?</b>","stepsSub":"Three steps to decide","intro":"Before you buy, ask yourself…","sources":[["🍎","Needs"],["🎮","Wants"],["🧠","Think"],["✅","Decide"]],"rule":"Buy <b>needs</b> before wants.","steps":[["ASK","need or want","🧠"],["WAIT","one day","⏳"],["CHOOSE","what matters","✅"]],"example":[["🍎","Need","$4"],["🎮","Want","$15"],["🐷","Saved","$11"]],"star":"Waiting a day stops <b>impulse</b> buys.","smartTitle":"SHOP <b>SMART</b>","parts":[["NEED","must have","🍎","e.g., lunch"],["WANT","nice to have","🎮","e.g., a game"],["WAIT","sleep on it","⏳","e.g., 1 day"]],"goal":"“Cover my needs, then save for <b>one</b> want.”","exIcons":"🍎 → 🧠 → 🐷","smartHead":"SMART SPENDING RULES","rules5":[["Needs come first","Food and clothes win."],["Name the want","Is it really a want?"],["Wait a day","The urge often fades."],["Check your money","Can you afford it?"],["Pick one want","Don't grab them all."]],"smartTip":"A want can wait; a need can't!","gbTitle":"SMART vs <b>IMPULSE</b>","gbSub":"Buying Choices","gbBody":"Some buys are planned and smart; others are quick impulse grabs.","gbKey":"Think before you buy.","kico":"🧠","tip":"Sleep on big wants overnight.","badHead":"IMPULSE","bad":[["⚡","Grab it now"],["🍭","Buy every candy"],["😬","Regret later"]],"badWarn":"Quick grabs waste money on stuff you forget!","goodHead":"SMART","good":[["🍎","Needs first"],["⏳","Wait a day"],["✅","Pick one want"]],"goodNote":"Smart choices leave money to save!"},
{"title":"BILL <b>MANAGEMENT</b> GRID","tag":"Pay On Time","blurb":"Some costs come back every month like clockwork. Learn to track them and pay on time, every time!","mission":"Learn to track recurring bills and pay them on time.","feats":[["🗓️","Know Due Dates"],["🧾","List Your Bills"],["💵","Set Money Aside"],["✅","Pay On Time"],["🔔","Use Reminders"]],"qTitle":"WHAT IS A<br><b>BILL?</b>","what":"A <b>bill</b> is money you owe that comes back on a regular schedule.","key":"Know what's due and pay it before the date.","swapBad":"“I'll pay it whenever.”","swapGood":"“It's due the 1st — I'll set it aside now.”","examplesHead":"COMMON BILLS","examples":[["📱","Phone plan"],["🎵","Music app"],["🎮","Game pass"],["📺","Streaming"],["🚌","Bus pass"]],"stepsTitle":"TRACK YOUR <b>BILLS</b>","stepsSub":"Three steps to never miss one","intro":"Stay on top of every bill…","sources":[["🧾","List them"],["🗓️","Due dates"],["💵","Set aside"],["✅","Pay it"]],"rule":"Pay <b>before</b> the due date.","steps":[["LIST","all your bills","🧾"],["SET","money aside","💵"],["PAY","on time","✅"]],"example":[["📱","Phone","$10"],["🎵","Music","$5"],["💵","Set aside","$15"]],"star":"On-time bills mean <b>no</b> late fees.","smartTitle":"BILL <b>BOSS</b>","parts":[["LIST","what you owe","🧾","e.g., phone"],["DATE","when it's due","🗓️","e.g., the 1st"],["PAY","set aside first","💵","e.g., $15"]],"goal":"“Set aside <b>$15</b> by the 1st for my monthly bills.”","exIcons":"🧾 → 🗓️ → ✅","smartHead":"SMART BILL RULES","rules5":[["Write down due dates","Don't trust memory."],["Set money aside early","Have it ready."],["Set a reminder","A beep beats a fine."],["Pay on time","Skip late fees."],["Review each month","Cancel what you skip."]],"smartTip":"A reminder beats a <b>late</b> fee!","gbTitle":"ON-TIME vs <b>LATE</b>","gbSub":"Bill Habits","gbBody":"Paying bills early keeps you calm; forgetting them costs extra.","gbKey":"Pay early, stay calm.","kico":"🗓️","tip":"Mark due dates on a calendar.","badHead":"LATE","bad":[["🙈","Forget the date"],["💸","Pay late fees"],["😰","Scramble for cash"]],"badWarn":"Late bills add fees and stress!","goodHead":"ON TIME","good":[["🗓️","Track dates"],["💵","Set aside early"],["✅","Pay on time"]],"goodNote":"On-time bills keep you stress-free!"},
{"title":"EMERGENCY FUND <b>VAULT</b>","tag":"Money For Surprises","blurb":"Life throws surprises — a broken bike, a lost ball. Build a money buffer so they don't break your budget!","mission":"Learn to build a savings buffer for surprise costs.","feats":[["🛟","Build A Buffer"],["⚠️","Plan Surprises"],["🔒","Keep It Safe"],["💵","Save Slowly"],["😌","Stay Calm"]],"qTitle":"WHAT IS AN<br><b>EMERGENCY FUND?</b>","what":"An <b>emergency fund</b> is money saved just for surprise costs.","key":"Save a little now so surprises don't hurt later.","swapBad":"“I'll worry about it when it breaks.”","swapGood":"“I keep $20 set aside just in case.”","examplesHead":"SURPRISE COSTS","examples":[["🚲","Bike repair"],["📱","Cracked screen"],["⚽","Lost ball"],["🩹","Scraped knee"],["🎒","Torn backpack"]],"stepsTitle":"BUILD YOUR <b>VAULT</b>","stepsSub":"Three steps to a safety buffer","intro":"Get ready before trouble hits…","sources":[["🎯","Set a goal"],["💵","Add a little"],["🔒","Keep it safe"],["🛟","Use if needed"]],"rule":"Save for the <b>unexpected</b>.","steps":[["GOAL","pick an amount","🎯"],["ADD","a little weekly","💵"],["LOCK","don't touch it","🔒"]],"example":[["🎯","Goal","$20"],["💵","Weekly","$2"],["🔒","Safe","$20"]],"star":"A buffer turns a crisis into a <b>shrug</b>.","smartTitle":"VAULT <b>BUILDER</b>","parts":[["GOAL","target amount","🎯","e.g., $20"],["ADD","save weekly","💵","e.g., $2"],["GUARD","only emergencies","🔒","e.g., a repair"]],"goal":"“Save <b>$2</b> a week until my vault hits $20.”","exIcons":"🎯 → 💵 → 🔒","smartHead":"SMART VAULT RULES","rules5":[["Start small","Even $1 counts."],["Save it first","Before you spend."],["Keep it separate","Don't mix it in."],["Use for true surprises","Not for candy."],["Refill after you use it","Build it back up."]],"smartTip":"A small buffer beats a <b>big</b> panic!","gbTitle":"READY vs <b>CAUGHT</b>","gbSub":"Surprise Costs","gbBody":"A buffer keeps surprises easy; no buffer leaves you stuck.","gbKey":"Be ready, not stuck.","kico":"🛟","tip":"Refill your vault after you use it.","badHead":"CAUGHT","bad":[["🤷","No backup"],["💸","Borrow money"],["😰","Big stress"]],"badWarn":"No buffer means surprises hurt a lot!","goodHead":"READY","good":[["🛟","Have a buffer"],["🔒","Keep it safe"],["😌","Stay calm"]],"goodNote":"A ready vault keeps surprises small!"},
{"title":"SMART SPENDING <b>PLAZA</b>","tag":"Spend On What Matters","blurb":"Not every dollar is worth it. Learn to spend on what you really value and skip the rest!","mission":"Learn to spend on what matters most to you.","feats":[["💎","Find The Value"],["🎯","Spend On Purpose"],["🤔","Compare Choices"],["✂️","Skip The Rest"],["😊","Love Your Buys"]],"qTitle":"WHAT IS<br><b>VALUE?</b>","what":"<b>Value</b> is how much joy or use you get for the money you spend.","key":"Spend on what you'll truly use and love.","swapBad":"“It's cheap, so I'll grab it.”","swapGood":"“Will I use this a lot? Then it's worth it.”","examplesHead":"WORTH IT vs NOT","examples":[["📚","Book you read"],["⚽","Ball you use"],["🎨","Art set you love"],["🧸","Toy you ignore"],["🗑️","Junk you toss"]],"stepsTitle":"SPEND ON <b>PURPOSE</b>","stepsSub":"Three steps to smart buys","intro":"Make every dollar count…","sources":[["💎","Value"],["🤔","Compare"],["🎯","Choose"],["😊","Enjoy"]],"rule":"Pay for <b>value</b>, not just price.","steps":[["ASK","will I use it","🤔"],["COMPARE","two choices","⚖️"],["BUY","what you value","🎯"]],"example":[["📚","Book","$8"],["🧸","Toy","$8"],["💎","Better pick","📚"]],"star":"The best buy is one you <b>actually</b> use.","smartTitle":"VALUE <b>HUNTER</b>","parts":[["USE","how often","🔁","e.g., daily"],["JOY","how happy","😊","e.g., a lot"],["COST","is it fair","💵","e.g., $8"]],"goal":"“Spend my <b>$8</b> on the thing I'll use the most.”","exIcons":"🤔 → ⚖️ → 🎯","smartHead":"SMART VALUE RULES","rules5":[["Ask if you'll use it","Use beats price."],["Compare two options","Pick the better one."],["Skip cheap junk","Cheap can be waste."],["Buy quality you'll keep","It lasts longer."],["Enjoy your choice","No buyer's regret."]],"smartTip":"Cheap junk costs more than a <b>good</b> buy!","gbTitle":"VALUE vs <b>WASTE</b>","gbSub":"Spending Choices","gbBody":"Some buys give real value; others are money wasted.","gbKey":"Buy use, not clutter.","kico":"💎","tip":"Ask how often you'll really use it.","badHead":"WASTE","bad":[["🏷️","Buy just cheap"],["🧸","Stuff you ignore"],["🗑️","Toss it later"]],"badWarn":"Cheap clutter wastes your money fast!","goodHead":"VALUE","good":[["💎","Real value"],["🔁","Use it often"],["😊","Love the buy"]],"goodNote":"Value buys make you happy longer!"},
{"title":"GOAL TRACKER <b>TOWER</b>","tag":"Reach Your Target","blurb":"Big goals feel far away — until you break them into steps. Watch your savings climb to the top!","mission":"Learn to set a goal and track your progress to it.","feats":[["🎯","Set A Goal"],["📊","Track Progress"],["🪜","Break It Down"],["🔥","Stay Motivated"],["🏆","Hit Your Target"]],"qTitle":"WHAT IS A<br><b>SAVINGS GOAL?</b>","what":"A <b>savings goal</b> is an amount you save toward something you want.","key":"Break a big goal into small steps you can track.","swapBad":"“I'll just save someday.”","swapGood":"“I'll save $5 a week to hit $30 in six weeks.”","examplesHead":"GOALS TO CHASE","examples":[["🚲","New bike"],["🎮","A game"],["🎸","A guitar"],["⚽","Soccer cleats"],["🎁","A gift"]],"stepsTitle":"CLIMB THE <b>TOWER</b>","stepsSub":"Three steps to reach your goal","intro":"One step at a time to the top…","sources":[["🎯","The goal"],["🪜","The steps"],["📊","The progress"],["🏆","The win"]],"rule":"Break it into <b>small</b> steps.","steps":[["SET","name your goal","🎯"],["SPLIT","into weekly bits","🪜"],["TRACK","each step up","📊"]],"example":[["🎯","Goal","$30"],["💵","Weekly","$5"],["🗓️","Weeks","6"]],"star":"Small steps add up to a <b>big</b> win.","smartTitle":"TOWER <b>CLIMBER</b>","parts":[["GOAL","the target","🎯","e.g., $30"],["STEP","weekly amount","💵","e.g., $5"],["TIME","weeks to go","🗓️","e.g., 6 weeks"]],"goal":"“Save <b>$5</b> a week to reach $30 in 6 weeks.”","exIcons":"🎯 → 🪜 → 🏆","smartHead":"SMART GOAL RULES","rules5":[["Pick one clear goal","Know what you want."],["Set a real amount","Give it a number."],["Split into steps","Save a bit weekly."],["Track every step","Watch it climb."],["Celebrate the win","You earned it!"]],"smartTip":"What you <b>track</b> is what you reach!","gbTitle":"PLANNED vs <b>VAGUE</b>","gbSub":"Goal Habits","gbBody":"A tracked goal gets reached; a vague wish drifts away.","gbKey":"Track it to reach it.","kico":"📊","tip":"Check your progress every week.","badHead":"VAGUE","bad":[["🌫️","No real plan"],["🤷","Never track"],["😴","Give up early"]],"badWarn":"A vague wish almost never comes true!","goodHead":"PLANNED","good":[["🎯","Clear goal"],["🪜","Small steps"],["📊","Track it"]],"goodNote":"A tracked goal gets reached!"},
{"title":"EFFICIENCY <b>LAB</b>","tag":"More From Each Dollar","blurb":"Smart spenders stretch every dollar further. Learn the tricks to get more bang for your buck!","mission":"Learn to get more value from every dollar you spend.","feats":[["🔬","Test The Price"],["📏","Compare Sizes"],["🏷️","Find Deals"],["♻️","Reuse & Save"],["💪","Stretch Dollars"]],"qTitle":"WHAT IS<br><b>EFFICIENCY?</b>","what":"<b>Efficiency</b> is getting the most value out of every dollar you spend.","key":"Compare options to get more for less.","swapBad":"“I'll grab the first one I see.”","swapGood":"“This size costs less per snack — better deal!”","examplesHead":"STRETCH TRICKS","examples":[["🏷️","Wait for sales"],["📦","Buy bigger size"],["🤝","Split with a friend"],["♻️","Reuse it"],["🔍","Compare prices"]],"stepsTitle":"OPTIMIZE YOUR <b>SPEND</b>","stepsSub":"Three steps to stretch a dollar","intro":"Squeeze more from your money…","sources":[["🔍","Compare"],["🏷️","Deals"],["📏","Price per unit"],["💪","Save more"]],"rule":"Get <b>more</b> for less.","steps":[["COMPARE","two prices","🔍"],["PICK","best per unit","📏"],["SAVE","the difference","🐷"]],"example":[["🥤","Big size","$0.50"],["🥤","Small size","$0.75"],["🐷","Saved","$0.25"]],"star":"A smart compare beats a <b>quick</b> grab.","smartTitle":"DOLLAR <b>STRETCHER</b>","parts":[["COMPARE","check prices","🔍","e.g., 2 sizes"],["UNIT","cost per item","📏","e.g., 50¢ each"],["SAVE","keep the rest","🐷","e.g., 25¢"]],"goal":"“Pick the size that costs <b>less</b> per snack and save the rest.”","exIcons":"🔍 → 📏 → 🐷","smartHead":"SMART EFFICIENCY RULES","rules5":[["Compare before buying","Don't grab blindly."],["Check price per unit","Bigger isn't always cheaper."],["Wait for a sale","Patience pays off."],["Share or split costs","Two save more."],["Reuse what you can","Waste less, keep more."]],"smartTip":"A few cents saved adds up <b>fast</b>!","gbTitle":"SMART vs <b>WASTEFUL</b>","gbSub":"Spending Habits","gbBody":"Smart spenders stretch dollars; wasteful ones let value slip.","gbKey":"Stretch every dollar.","kico":"🔬","tip":"Check the price per unit, not just the tag.","badHead":"WASTEFUL","bad":[["🏃","Grab fast"],["🙉","Skip compare"],["🗑️","Waste leftovers"]],"badWarn":"Grabbing fast leaves money on the table!","goodHead":"SMART","good":[["🔍","Compare first"],["📏","Best per unit"],["♻️","Reuse & save"]],"goodNote":"Smart moves stretch every dollar!"}]
