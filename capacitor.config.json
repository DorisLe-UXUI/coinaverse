{
  "appId": "com.coincept.coinaverse",
  "appName": "Coinaverse",
  "webDir": ".",
  "server": {
    "url": "https://coinaverse-app.vercel.app",
    "cleartext": true,
    "allowNavigation": ["coinaverse-app.vercel.app"]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#030612",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#030612"
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark"
    }
  },
  "ios": {
    "scheme": "Coinaverse",
    "backgroundColor": "#030612"
  },
  "android": {
    "backgroundColor": "#030612",
    "allowMixedContent": true
  }
}
